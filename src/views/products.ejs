<%- include('includes/header', { title: 'Menu', page: 'products' }) %>

<main style="padding-top: var(--nav-h);">

  <!-- Page header -->
  <div class="page-header">
    <div class="container">
      <h1 class="section-title" style="color:var(--white);">Our Menu</h1>
      <p style="color:rgba(255,255,255,0.65);">Fresh ingredients, bold flavors, unforgettable taste</p>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <!-- Filter bar -->
      <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-bottom:2.5rem; align-items:center;">
        <button class="btn btn-primary filter-btn" onclick="filterCategory('all', this)">All</button>
        <button class="btn btn-outline filter-btn" onclick="filterCategory('starter', this)">Starters</button>
        <button class="btn btn-outline filter-btn" onclick="filterCategory('main', this)">Mains</button>
        <button class="btn btn-outline filter-btn" onclick="filterCategory('dessert', this)">Desserts</button>
        <button class="btn btn-outline filter-btn" onclick="filterCategory('drink', this)">Drinks</button>
        <div style="margin-left:auto;">
          <input type="text" class="table-search" placeholder="🔍 Search dishes..." oninput="searchProducts(this.value)" />
        </div>
      </div>

      <!-- Product Grid -->
      <% if (typeof products !== 'undefined' && products.length > 0) { %>
        <div class="card-grid card-grid-3" id="productGrid">
          <% products.forEach(function(p) { %>
            <article class="card product-card" data-category="<%= p.category || 'main' %>">
              <% if (p.productImage) { %>
                <img class="card-img" src="<%= p.productImage %>" alt="<%= p.productName %>" />
              <% } else { %>
                <div class="card-img-placeholder">
                  <%= p.category === 'dessert' ? '🍰' : p.category === 'starter' ? '🥗' : p.category === 'drink' ? '🥤' : '🍽️' %>
                </div>
              <% } %>
              <div class="card-body">
                <div class="card-tag"><%= p.category || 'Main Course' %></div>
                <h3 class="card-title"><%= p.productName %></h3>
                <p class="card-desc"><%= p.productDesc || 'Freshly prepared with premium ingredients.' %></p>
                <div class="card-footer">
                  <span class="card-price">$<%= p.productPrice ? p.productPrice.toFixed(2) : '0.00' %></span>
                  <button class="btn btn-primary" onclick="addToCart('<%= p._id %>', '<%= p.productName %>')">
                    + Add
                  </button>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

      <% } else { %>
        <!-- Placeholder cards when no DB products yet -->
        <div class="card-grid card-grid-3" id="productGrid">

          <% const placeholders = [
            { emoji:'🥗', tag:'Starter', name:'Garden Mezze Platter', desc:'Hummus, baba ganoush, tabbouleh, fresh pita. A perfect starter for sharing.', price:'18.00', cat:'starter' },
            { emoji:'🥙', tag:'Starter', name:'Stuffed Grape Leaves', desc:'Tender grape leaves filled with seasoned rice, herbs, and pine nuts.', price:'12.00', cat:'starter' },
            { emoji:'🍖', tag:'Main Course', name:'Slow-Roasted Lamb Leg', desc:'24-hour marinated lamb with roasted vegetables and aromatic spices.', price:'36.00', cat:'main' },
            { emoji:'🍗', tag:'Main Course', name:'Grilled Chicken Shawarma', desc:'Spiced chicken strips with garlic sauce, pickles, and fresh herbs.', price:'22.00', cat:'main' },
            { emoji:'🫕', tag:'Main Course', name:'Beef Tagine', desc:'Slow-cooked beef with apricots, almonds, and warm Moroccan spices.', price:'29.00', cat:'main' },
            { emoji:'🥘', tag:'Main Course', name:'Vegetable Couscous', desc:'Fluffy couscous topped with seven seasonal vegetables and harissa.', price:'19.00', cat:'main' },
            { emoji:'🍰', tag:'Dessert', name:'Baklava Supreme', desc:'Layered phyllo pastry with pistachios, walnuts, and rose-water honey.', price:'9.00', cat:'dessert' },
            { emoji:'🍮', tag:'Dessert', name:'Kunafa', desc:'Crispy shredded pastry soaked in sweet syrup with creamy cheese filling.', price:'11.00', cat:'dessert' },
            { emoji:'🥤', tag:'Drink', name:'Fresh Mint Lemonade', desc:'Freshly squeezed lemons blended with garden mint and a hint of sweetness.', price:'6.00', cat:'drink' },
          ]; %>

          <% placeholders.forEach(function(p) { %>
            <article class="card product-card" data-category="<%= p.cat %>">
              <div class="card-img-placeholder"><%= p.emoji %></div>
              <div class="card-body">
                <div class="card-tag"><%= p.tag %></div>
                <h3 class="card-title"><%= p.name %></h3>
                <p class="card-desc"><%= p.desc %></p>
                <div class="card-footer">
                  <span class="card-price">$<%= p.price %></span>
                  <button class="btn btn-primary">+ Add</button>
                </div>
              </div>
            </article>
          <% }) %>

        </div>
      <% } %>

    </div>
  </section>
</main>

<script>
// Category filter
function filterCategory(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.className = 'btn btn-outline filter-btn';
  });
  btn.className = 'btn btn-primary filter-btn';
  document.querySelectorAll('.product-card').forEach(card => {
    card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
  });
}

// Search
function searchProducts(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('.product-card').forEach(card => {
    card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

// Add to cart placeholder
function addToCart(id, name) {
  const btn = event.target;
  btn.textContent = '✓ Added!';
  btn.style.background = 'var(--green)';
  setTimeout(() => { btn.textContent = '+ Add'; btn.style.background = ''; }, 1500);
}
</script>

<%- include('includes/footer') %>
