<%- include('includes/header', { title: 'Sign Up', page: 'signup' }) %>

<main class="form-wrap">
  <div class="form-card">

    <div class="form-logo">Bur<span>ak</span></div>
    <p class="form-subtitle">Create your free account and start earning rewards.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>

    <form action="/signup" method="POST" id="signupForm" novalidate>

      <div class="form-group">
        <label class="form-label" for="memberNick">Username</label>
        <div class="form-input-icon">
          <span class="icon">👤</span>
          <input
            class="form-input"
            type="text"
            id="memberNick"
            name="memberNick"
            placeholder="Choose a unique username"
            value="<%= typeof formData !== 'undefined' ? formData.memberNick || '' : '' %>"
            required
            minlength="3"
            autocomplete="username"
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="memberPhone">Phone Number</label>
        <div class="form-input-icon">
          <span class="icon">📱</span>
          <input
            class="form-input"
            type="tel"
            id="memberPhone"
            name="memberPhone"
            placeholder="+998 90 000 00 00"
            value="<%= typeof formData !== 'undefined' ? formData.memberPhone || '' : '' %>"
            required
            autocomplete="tel"
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="memberPassword">Password</label>
        <div class="form-input-icon">
          <span class="icon">🔒</span>
          <input
            class="form-input"
            type="password"
            id="memberPassword"
            name="memberPassword"
            placeholder="At least 6 characters"
            required
            minlength="6"
            autocomplete="new-password"
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="memberAddress">Address <span style="color:var(--text-muted);font-weight:400;">(optional)</span></label>
        <div class="form-input-icon">
          <span class="icon">📍</span>
          <input
            class="form-input"
            type="text"
            id="memberAddress"
            name="memberAddress"
            placeholder="Your delivery address"
            autocomplete="street-address"
          />
        </div>
      </div>

      <p style="font-size:0.8rem; color:var(--text-muted); margin-bottom:1rem;">
        By signing up you agree to our <a href="#" style="color:var(--primary);">Terms</a> and <a href="#" style="color:var(--primary);">Privacy Policy</a>.
      </p>

      <button type="submit" class="btn btn-primary btn-full btn-lg">
        Create Account →
      </button>

    </form>

    <div class="form-divider">or</div>

    <a href="/admin/signup" class="btn btn-outline btn-full" style="margin-bottom:1rem;">
      🏪 Register as Restaurant
    </a>

    <div class="form-footer">
      Already have an account? <a href="/login">Log in</a>
    </div>

  </div>
</main>

<%- include('includes/footer') %>
