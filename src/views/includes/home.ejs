<%- include('includes/header', { title: 'Home', page: 'home' }) %>

<!-- ── HERO ───────────────────────────────────────── -->
<section class="hero">
  <div class="hero-image">
    <img src="/img/hero-food.jpg" alt="Delicious food" onerror="this.style.display='none'" />
  </div>
  <div class="container" style="position:relative; z-index:1;">
    <div class="hero-content">
      <div class="hero-badge">✨ Premium Dining Experience</div>
      <h1>Where Every Meal<br/>Becomes <em>Unforgettable</em></h1>
      <p>
        Discover authentic flavors crafted by our expert chefs.
        Fresh ingredients, bold recipes, and memories that last a lifetime.
      </p>
      <div class="hero-actions">
        <a href="/products" class="btn btn-primary btn-lg">Explore Menu</a>
        <a href="/signup" class="btn btn-lg" style="background:rgba(255,255,255,0.12);color:#fff;border:2px solid rgba(255,255,255,0.3);">
          Join Today →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── STATS ──────────────────────────────────────── -->
<div class="stats-bar">
  <div class="stats-inner">
    <div class="stat-item">
      <div class="stat-num">200+</div>
      <div class="stat-label">Menu Items</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">15k+</div>
      <div class="stat-label">Happy Customers</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">12</div>
      <div class="stat-label">Expert Chefs</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">4.9★</div>
      <div class="stat-label">Average Rating</div>
    </div>
  </div>
</div>

<!-- ── FEATURED DISHES ────────────────────────────── -->
<section class="section" style="background:var(--bg);">
  <div class="container">
    <div class="section-center">
      <h2 class="section-title">Our Signature Dishes</h2>
      <p class="section-subtitle">Handpicked favorites from our kitchen to your table</p>
    </div>
    <div class="card-grid card-grid-3">

      <article class="card fade-up">
        <div class="card-img-placeholder">🍖</div>
        <div class="card-body">
          <div class="card-tag">Best Seller</div>
          <h3 class="card-title">Slow-Roasted Lamb</h3>
          <p class="card-desc">Tender lamb marinated overnight with aromatic herbs and slow-cooked to perfection.</p>
          <div class="card-footer">
            <span class="card-price">$28.00</span>
            <a href="/products" class="btn btn-primary">Order Now</a>
          </div>
        </div>
      </article>

      <article class="card fade-up-2">
        <div class="card-img-placeholder">🥗</div>
        <div class="card-body">
          <div class="card-tag">Chef's Choice</div>
          <h3 class="card-title">Mezze Platter</h3>
          <p class="card-desc">A colorful spread of hummus, baba ganoush, fresh vegetables, and warm flatbread.</p>
          <div class="card-footer">
            <span class="card-price">$18.00</span>
            <a href="/products" class="btn btn-primary">Order Now</a>
          </div>
        </div>
      </article>

      <article class="card fade-up-3">
        <div class="card-img-placeholder">🍰</div>
        <div class="card-body">
          <div class="card-tag">Dessert</div>
          <h3 class="card-title">Baklava Supreme</h3>
          <p class="card-desc">Layers of flaky phyllo pastry, crushed pistachios, and golden honey syrup.</p>
          <div class="card-footer">
            <span class="card-price">$9.00</span>
            <a href="/products" class="btn btn-primary">Order Now</a>
          </div>
        </div>
      </article>

    </div>
    <div class="text-center mt-3">
      <a href="/products" class="btn btn-outline btn-lg">View Full Menu →</a>
    </div>
  </div>
</section>

<!-- ── WHY US ──────────────────────────────────────── -->
<section class="section" style="background:var(--bg-warm);">
  <div class="container">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">
      <div>
        <h2 class="section-title">Why Guests Love <span class="text-primary">Burak</span></h2>
        <p class="section-subtitle">More than a restaurant — a culinary journey.</p>
        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon">🌿</div>
            <div class="feature-text">
              <h4>Farm-Fresh Ingredients</h4>
              <p>Every dish starts with premium, locally sourced ingredients picked at peak freshness.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">👨‍🍳</div>
            <div class="feature-text">
              <h4>Master Chefs</h4>
              <p>Our chefs bring decades of culinary expertise and passion to every single plate.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">🚀</div>
            <div class="feature-text">
              <h4>Fast Delivery</h4>
              <p>Order online and receive your food hot and fresh within 30 minutes.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">💎</div>
            <div class="feature-text">
              <h4>Loyalty Rewards</h4>
              <p>Earn points with every order and redeem them for exclusive discounts and perks.</p>
            </div>
          </div>
        </div>
      </div>
      <div style="background:var(--white); border-radius:var(--radius-lg); padding:2.5rem; border:1px solid var(--border); box-shadow:var(--shadow-md);">
        <h3 style="font-family:var(--font-display); font-size:1.5rem; margin-bottom:0.5rem;">Join Our Community</h3>
        <p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:1.5rem;">Create a free account and start earning rewards with your first order.</p>
        <% if (typeof member === 'undefined' || !member) { %>
          <a href="/signup" class="btn btn-primary btn-full btn-lg" style="margin-bottom:0.75rem;">Create Free Account</a>
          <a href="/login" class="btn btn-outline btn-full">Already a member? Log in</a>
        <% } else { %>
          <div style="text-align:center; padding:1rem;">
            <div style="font-size:2.5rem; margin-bottom:0.5rem;">🎉</div>
            <p style="font-weight:600;">Welcome back, <%= member.memberNick %>!</p>
            <p style="color:var(--text-muted); font-size:0.9rem;">You have <strong style="color:var(--primary);"><%= member.memberPoints || 0 %> points</strong></p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ───────────────────────────────── -->
<section class="section" style="background:var(--bg);">
  <div class="container">
    <div class="section-center">
      <h2 class="section-title">What Our Guests Say</h2>
      <p class="section-subtitle">Real reviews from real food lovers</p>
    </div>
    <div class="card-grid card-grid-3">

      <div class="testimonial-card fade-up">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"The lamb was cooked to absolute perfection. I've been to many restaurants but Burak stands out in every way possible."</p>
        <div class="testimonial-author">
          <div class="avatar">AK</div>
          <div>
            <div class="testimonial-name">Aziz Karimov</div>
            <div class="testimonial-role">Food Blogger</div>
          </div>
        </div>
      </div>

      <div class="testimonial-card fade-up-2">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"Ordered delivery and the food arrived hot and fresh within 25 minutes. The packaging was beautiful and the taste was outstanding!"</p>
        <div class="testimonial-author">
          <div class="avatar">SN</div>
          <div>
            <div class="testimonial-name">Sabohat Nazarova</div>
            <div class="testimonial-role">Regular Customer</div>
          </div>
        </div>
      </div>

      <div class="testimonial-card fade-up-3">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"The loyalty points system is amazing! I've saved so much already. The baklava is simply heaven on a plate."</p>
        <div class="testimonial-author">
          <div class="avatar">JM</div>
          <div>
            <div class="testimonial-name">Jasur Mirzayev</div>
            <div class="testimonial-role">VIP Member</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%- include('includes/footer') %>
